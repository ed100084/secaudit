# LLM backend: openrouter | cli-proxy
LLM_BACKEND=openrouter

# OpenRouter LLM
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=google/gemini-2.5-flash-preview-05-20

# CLIProxyAPI / OpenAI-compatible endpoint
# Example: http://host.docker.internal:8080/v1 when CLIProxyAPI runs on the Docker host
CLI_PROXY_URL=http://host.docker.internal:8080/v1
CLI_PROXY_API_KEY=
CLI_PROXY_MODEL=local-model

# App
SECAUDIT_API_KEY=change-me-to-a-strong-key
SECAUDIT_PORT=8000
ALLOWED_ORIGINS=http://localhost:8000
